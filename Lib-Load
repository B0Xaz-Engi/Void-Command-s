                end
            end
        end
    end)

    -- Animate in elements
    task.wait(0.25)
    local CommandInput = Main.CommandInput
    local CommandInputStroke = CommandInput.CommandInputStroke
    local CloseButton = Main.CloseButton
    local CommandsHolder = Main.CommandsHolder
    local CommandsHolderScrolling = CommandsHolder.CommandsHolderScrolling

    for _, Element in next, Main:GetChildren() do
        if Element:IsA('TextBox') or Element:IsA('TextLabel') or Element:IsA('TextButton') or Element:IsA('ImageButton') then
            Element.Visible = true
            if Utility:HasProperty(Element, 'BackgroundTransparency') then
                Utility:Tween(Element, {BackgroundTransparency = 0}, 0.25)
            end
            if Utility:HasProperty(Element, 'TextTransparency') then
                Utility:Tween(Element, {TextTransparency = 0}, 0.25)
            end
            if Utility:HasProperty(Element, 'ImageTransparency') then
                Utility:Tween(Element, {ImageTransparency = 0}, 0.25)
            end
        end
    end

    CommandInputStroke.Thickness = 1

    CloseButton.MouseEnter:Connect(function()
        Utility:Tween(CloseButton, {TextColor3 = Utility:Darken(Theme.PrimaryTextColor)}, 0.25)
    end)

    CloseButton.MouseLeave:Connect(function()
        Utility:Tween(CloseButton, {TextColor3 = Theme.PrimaryTextColor}, 0.25)
    end)

    -- ────────────────────────────────────────────────
    --               Command List Size Update
    -- ────────────────────────────────────────────────

    local function UpdateFrameSizes()
        local Count = 0
        for _, Instance in next, CommandsHolderScrolling:GetChildren() do
            if not Instance:IsA('UIListLayout') and Instance.Visible then
                Count += 1
            end
        end

        local Size = Count * 30
        local Padding = 3 * Count
        Size = Size + Padding - 3

        if Count == 0 then
            Utility:Tween(CommandsHolder, {Size = UDim2.new(0, 500, 0, 0)}, 0.25)
            Utility:Tween(CommandsHolderScrolling, {Size = UDim2.new(0, 500, 0, Size)}, 0.25)
            Utility:Tween(CommandsHolderScrolling, {CanvasSize = UDim2.new(0, 500, 0, Size)}, 0.25)
        elseif Count < 9 then
            Utility:Tween(CommandsHolder, {Size = UDim2.new(0, 500, 0, Size + 10)}, 0.25)
            Utility:Tween(CommandsHolderScrolling, {Size = UDim2.new(0, 500, 0, Size)}, 0.25)
            Utility:Tween(CommandsHolderScrolling, {CanvasSize = UDim2.new(0, 500, 0, Size)}, 0.25)

            if isBottom then
                if Main.Position.Y.Offset < 0 then
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset - Size - 13)}, 0.25)
                else
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset - Size + 22)}, 0.25)
                end
            else
                if Main.Position.Y.Offset > 0 then
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset - 3)}, 0.25)
                else
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset + 33)}, 0.25)
                end
            end
        else
            Utility:Tween(CommandsHolder, {Size = UDim2.new(0, 500, 0, 270)}, 0.25)
            Utility:Tween(CommandsHolderScrolling, {Size = UDim2.new(0, 500, 0, 260)}, 0.25)
            Utility:Tween(CommandsHolderScrolling, {CanvasSize = UDim2.new(0, 500, 0, Size)}, 0.25)

            if isBottom then
                if Main.Position.Y.Offset < 0 then
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset - 273)}, 0.25)
                else
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset - 237)}, 0.25)
                end
            else
                if Main.Position.Y.Offset > 0 then
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset - 3)}, 0.25)
                else
                    Utility:Tween(CommandsHolder, {Position = UDim2.new(0, 0, 0, -Main.Position.Y.Offset + 33)}, 0.25)
                end
            end
        end
    end

    CommandsHolderScrolling.ChildAdded:Connect(UpdateFrameSizes)
    CommandsHolderScrolling.ChildRemoved:Connect(UpdateFrameSizes)

    -- Close button
    CloseButton.MouseButton1Down:Connect(function()
        Utility:Tween(CloseButton, {TextColor3 = Utility:Darken(Theme.PrimaryTextColor)}, 0.25)
        task.wait(0.25)
        Utility:Tween(CloseButton, {TextColor3 = Theme.PrimaryTextColor}, 0.25)
        task.wait(0.25)
        Utility:Destroy()
    end)

    -- Prefix open
    UserInputService.InputBegan:Connect(function(Input, GameProcessed)
        if GameProcessed then return end
        if Input.KeyCode == Library.Prefix then
            UpdateFrameSizes()
            CommandInput:CaptureFocus()

            if isBottom then
                Utility:Tween(Main, {Position = Main.Position + UDim2.new(0,0,0,-36)}, 0.25)
            else
                Utility:Tween(Main, {Position = Main.Position + UDim2.new(0,0,0,36)}, 0.25)
            end

            task.wait(0.25)
            CommandsHolder.Visible = true
            Utility:Tween(CommandsHolder, {BackgroundTransparency = 0.25}, 0.25)
            task.wait(0.25)

            for _, v in next, CommandsHolderScrolling:GetDescendants() do
                if not v:IsA('UIListLayout') and not v:IsA('TextButton') then
                    if v:IsA('Frame') then
                        Utility:Tween(v, {BackgroundTransparency = 0.25}, 0.25)
                    end
                    if Utility:HasProperty(v, 'TextTransparency') then
                        Utility:Tween(v, {TextTransparency = 0}, 0.25)
                    end
                end
            end
        end
    end)

    -- ────────────────────────────────────────────────
    --               Command Execution
    -- ────────────────────────────────────────────────

    local HoverDebounce = false

    local function Execute(str)
        if str == "" then return end

        local split = str:split(" ")
        local cmdName = split[1]:lower():gsub(Utility:KeyCodeToString(Library.Prefix), "")
        local args = {}

        for i = 2, #split do
            table.insert(args, split[i])
        end

        local command = Commands[cmdName]
        if not command then
            Utility:Log('error', 'Command not found: ' .. cmdName)
            return
        end

        if #args < #command.Arguments then
            Utility:Log('error', 'Missing arguments for: ' .. cmdName)
            return
        end

        task.spawn(command.Callback, args, Players.LocalPlayer)

        -- Close UI after execution
        CommandInput.Text = ""

        if not HoverDebounce then
            HoverDebounce = true
            task.delay(0.5, function() HoverDebounce = false end)

            if isBottom then
                for _, v in next, CommandsHolderScrolling:GetDescendants() do
                    if not v:IsA('UIListLayout') and not v:IsA('TextButton') then
                        if v:IsA('Frame') then Utility:Tween(v, {BackgroundTransparency = 1}, 0.25) end
                        if Utility:HasProperty(v, 'TextTransparency') then Utility:Tween(v, {TextTransparency = 1}, 0.25) end
                    end
                end
                task.wait(0.25)
                Utility:Tween(Main, {Position = Main.Position + UDim2.new(0,0,0,36)}, 0.25)
                task.wait(0.25)
                Utility:Tween(CommandsHolder, {BackgroundTransparency = 1}, 0.25)
                task.wait(0.25)
                CommandsHolder.Visible = false
            else
                for _, v in next, CommandsHolderScrolling:GetDescendants() do
                    if not v:IsA('UIListLayout') and not v:IsA('TextButton') then
                        if v:IsA('Frame') then Utility:Tween(v, {BackgroundTransparency = 1}, 0.25) end
                        if Utility:HasProperty(v, 'TextTransparency') then Utility:Tween(v, {TextTransparency = 1}, 0.25) end
                    end
                end
                task.wait(0.25)
                Utility:Tween(CommandsHolder, {BackgroundTransparency = 1}, 0.25)
                task.wait(0.25)
                Utility:Tween(Main, {Position = Main.Position + UDim2.new(0,0,0,-36)}, 0.25)
                task.wait(0.25)
                CommandsHolder.Visible = false
            end
        end
    end

    -- Live search / filter
    CommandInput:GetPropertyChangedSignal("Text"):Connect(function()
        local input = CommandInput.Text:lower():gsub(Utility:KeyCodeToString(Library.Prefix), "")

        if input == "" then
            for _, child in next, CommandsHolderScrolling:GetChildren() do
                if not child:IsA("UIListLayout") then
                    child.Visible = true
                end
            end
        else
            for _, child in next, CommandsHolderScrolling:GetChildren() do
                if not child:IsA("UIListLayout") then
                    child.Visible = string.find(child.Name:lower(), input) ~= nil
                end
            end
        end

        UpdateFrameSizes()
    end)

    -- Execute on enter
    CommandInput.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            Execute(CommandInput.Text)
        end
    end)

    -- ────────────────────────────────────────────────
    --               Tooltip System
    -- ────────────────────────────────────────────────

    local function CreateToolTip(text, plainText, enabled)
        local tooltip = Container.ToolTip

        if enabled and text then
            local size = TextService:GetTextSize(plainText, tooltip.TextSize, tooltip.Font, Vector2.new(300, math.huge))
            Utility:Tween(tooltip, {Size = UDim2.new(0, size.X + 10, 0, size.Y + 10)}, 0.1)

            RunService:BindToRenderStep("TooltipFollow", Enum.RenderPriority.Input.Value, function()
                local mouse = UserInputService:GetMouseLocation()
                local vp = Workspace.CurrentCamera.ViewportSize
                tooltip.Position = UDim2.new(0, mouse.X + 15, 0, mouse.Y + 15)
            end)

            tooltip.Text = text
            tooltip.Visible = true
        else
            tooltip.Visible = false
            RunService:UnbindFromRenderStep("TooltipFollow")
        end
    end

    -- ────────────────────────────────────────────────
    --               Window API
    -- ────────────────────────────────────────────────

    local Window = {}

    function Window:ChangePrefix(newPrefix)
        Library.Prefix = Utility:StringToKeyCode(tostring(newPrefix))
    end

    function Window:AddTheme(name, themeTable)
        Library.Themes[name:lower()] = themeTable
    end

    function Window:ChangeTheme(newTheme)
        if type(newTheme) == "table" then
            Library.Theme = newTheme
            Library.Themes.custom = newTheme
        elseif Library.Themes[newTheme:lower()] then
            Library.Theme = Library.Themes[newTheme:lower()]
        else
            return Utility:Log("error", "Theme not found: " .. tostring(newTheme))
        end
        ChangeTheme = true
        task.delay(0.3, function() ChangeTheme = false end)
    end

    function Window:CreateNotification(title, text, duration)
        duration = duration or 5

        local count = 0
        for _, v in next, Container:GetChildren() do
            if v.Name:match("^Notification") then count += 1 end
        end

        local notif = Utility:Create("Frame", {
            Name = "Notification" .. (count + 1),
            Parent = Container,
            BackgroundColor3 = Library.Theme.BackgroundColor,
            Position = UDim2.new(1, 320, 1, -80 - (count * 60)),
            Size = UDim2.new(0, 300, 0, 60),
            AnchorPoint = Vector2.new(1,1)
        }, {
            Utility:Create("UICorner", {CornerRadius = UDim.new(0,6)}),
            Utility:Create("UIStroke", {Color = Library.Theme.AccentColor, Thickness = 1}),
            Utility:Create("TextLabel", {
                Name = "Title",
                Size = UDim2.new(1,0,0,25),
                BackgroundTransparency = 1,
                Text = title or "Notification",
                TextColor3 = Library.Theme.PrimaryTextColor,
                Font = Enum.Font.GothamBold,
                TextSize = 16,
                TextXAlignment = Enum.TextXAlignment.Left
            }, {Utility:Create("UIPadding", {PaddingLeft = UDim.new(0,12)})}),
            Utility:Create("TextLabel", {
                Name = "Text",
                Size = UDim2.new(1,0,0,30),
                Position = UDim2.new(0,0,0,25),
                BackgroundTransparency = 1,
                Text = text or "",
                TextColor3 = Library.Theme.SecondaryTextColor,
                Font = Enum.Font.Gotham,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true
            }, {Utility:Create("UIPadding", {PaddingLeft = UDim.new(0,12)})})
        })

        local textSize = TextService:GetTextSize(text or "", 14, Enum.Font.Gotham, Vector2.new(280, math.huge))
        notif.Size = UDim2.new(0, 300, 0, textSize.Y + 35)

        Utility:Tween(notif, {Position = UDim2.new(1, -20, 1, -80 - (count * 60))}, 0.4)

        task.delay(duration, function()
            Utility:Tween(notif, {BackgroundTransparency = 1}, 0.4)
            Utility:Tween(notif.Title, {TextTransparency = 1}, 0.4)
            Utility:Tween(notif.Text, {TextTransparency = 1}, 0.4)
            task.wait(0.4)
            notif:Destroy()
        end)
    end

    function Window:AddCommand(name, args, desc, callback)
        Commands[name:lower()] = {
            Arguments = args or {},
            Description = desc or "",
            Callback = callback
        }

        local function buildRichText()
            local str = '<font color="rgb('..math.floor(Theme.PrimaryTextColor.R*255)..','..math.floor(Theme.PrimaryTextColor.G*255)..','..math.floor(Theme.PrimaryTextColor.B*255)..')">' .. name .. '</font> '
            for _, arg in ipairs(args or {}) do
                str = str .. '<font color="rgb('..math.floor(Theme.SecondaryTextColor.R*255)..','..math.floor(Theme.SecondaryTextColor.G*255)..','..math.floor(Theme.SecondaryTextColor.B*255)..')">{'
                .. arg .. '}</font> '
            end
            str = str .. '<font color="rgb('..math.floor(Theme.AccentColor.R*255)..','..math.floor(Theme.AccentColor.G*255)..','..math.floor(Theme.AccentColor.B*255)..')">| </font>'
            str = str .. '<font color="rgb('..math.floor(Theme.SecondaryTextColor.R*255)..','..math.floor(Theme.SecondaryTextColor.G*255)..','..math.floor(Theme.SecondaryTextColor.B*255)..')">' .. (desc or "") .. '</font>'
            return str
        end

        local holder = Utility:Create("Frame", {
            Parent = CommandsHolderScrolling,
            BackgroundColor3 = Theme.BackgroundColor,
            BackgroundTransparency = 0.25,
            Name = name .. "CommandHolder",
            Size = UDim2.new(0, 490, 0, 30)
        }, {
            Utility:Create("UICorner", {CornerRadius = UDim.new(0,5)}),
            Utility:Create("TextLabel", {
                Name = name .. "Text",
                BackgroundTransparency = 1,
                RichText = true,
                Size = UDim2.new(1,0,1,0),
                Font = Enum.Font.Gotham,
                Text = buildRichText(),
                TextColor3 = Theme.PrimaryTextColor,
                TextSize = 15,
                TextXAlignment = Enum.TextXAlignment.Left
            }, {Utility:Create("UIPadding", {PaddingLeft = UDim.new(0,8)})}),
            Utility:Create("TextButton", {
                Name = name .. "Button",
                Size = UDim2.new(1,0,1,0),
                BackgroundTransparency = 1,
                Text = ""
            }, {Utility:Create("UICorner", {CornerRadius = UDim.new(0,5)})})
        })

        local btn = holder[name .. "Button"]

        btn.MouseButton1Click:Connect(function()
            Execute(name)
        end)

        holder.MouseEnter:Connect(function()
            Utility:Tween(holder, {BackgroundColor3 = Utility:Lighten(Theme.BackgroundColor)}, 0.15)
            CreateToolTip(buildRichText(), name .. " " .. table.concat(args or {}, " ") .. " | " .. (desc or ""), true)
        end)

        holder.MouseLeave:Connect(function()
            Utility:Tween(holder, {BackgroundColor3 = Theme.BackgroundColor}, 0.15)
            CreateToolTip(nil, nil, false)
        end)

        UpdateFrameSizes()
    end

    return Window
end

return Library
