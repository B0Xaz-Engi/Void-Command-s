-- ============================================================
-- OWN COMMAND REGISTRY
-- We intercept Window:AddCommand to store every callback
-- ourselves. This means our chat hook can call them directly
-- without relying on any library method like ExecuteCommand
-- which may not exist.
-- ============================================================
local prefix   = ';'
local Registry = {}   -- Registry['goto'] = callback

local _libAddCommand = Window.AddCommand
Window.AddCommand = function(self, cmdName, args, desc, callback)
    Registry[cmdName:lower()] = callback
    return _libAddCommand(self, cmdName, args, desc, callback)
end

-- ============================================================
-- CHAT EXECUTION ENGINE
-- Parses a raw chat string and runs the matching command.
-- ============================================================
local function execute(msg)
    if type(msg) ~= 'string' then return end
    msg = msg:match('^%s*(.-)%s*$') -- trim whitespace
    if msg:sub(1, #prefix) ~= prefix then return end
    msg = msg:sub(#prefix + 1)

    local parts = {}
    for w in msg:gmatch('%S+') do parts[#parts + 1] = w end
    if #parts == 0 then return end

    local cmd  = parts[1]:lower()
    local args = {}
    for i = 2, #parts do args[#args + 1] = parts[i] end

    local fn = Registry[cmd]
    if fn then
        local ok, err = pcall(fn, args, LocalPlayer)
        if not ok then
            N('Error', '[' .. cmd .. ']: ' .. tostring(err), 5)
            warn('[V0id cmd error] ' .. cmd .. ': ' .. tostring(err))
        end
    else
        -- silent fail for unknown commands so normal chat works
    end
end

-- Hook 1: LocalPlayer.Chatted (fires on server-confirmed messages)
LocalPlayer.Chatted:Connect(function(msg)
    execute(msg)
end)

-- Hook 2: TextBox Enter press — fires BEFORE the server sees it
-- so commands work even when Chatted is blocked/delayed
task.spawn(function()
    -- Wait a moment for PlayerGui to populate
    task.wait(2)
    local pg = LocalPlayer:WaitForChild('PlayerGui', 10)
    if not pg then return end

    -- Watch for any TextBox focus+enter across all GUIs
    UserInputService.InputBegan:Connect(function(inp, gpe)
        if inp.KeyCode ~= Enum.KeyCode.Return and
           inp.KeyCode ~= Enum.KeyCode.KeypadEnter then return end
        for _, v in pairs(pg:GetDescendants()) do
            if v:IsA('TextBox') and v:IsFocused() then
                local txt = v.Text
                -- defer so the TextBox registers the Enter first
                task.defer(function() execute(txt) end)
                return
            end
        end
    end)
end)

