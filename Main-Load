Window:AddCommand('Orbit', {'Player'}, 'Orbits around a player.', function(Arguments, Speaker)
    local target = findPlayer(Arguments[1])
    if not target then return end
    if orbitConnection then orbitConnection:Disconnect() end
    local angle = 0
    orbitConnection = RunService.Heartbeat:Connect(function(dt)
        local tHRP = target.Character and target.Character:FindFirstChild('HumanoidRootPart')
        local hrp = getHRP(Speaker)
        if tHRP and hrp then
            angle = angle + dt * 2
            local x = tHRP.Position.X + math.cos(angle) * 10
            local z = tHRP.Position.Z + math.sin(angle) * 10
            hrp.CFrame = CFrame.new(x, tHRP.Position.Y, z)
        end
    end)
    Window:CreateNotification('Orbit', 'Orbiting ' .. target.Name .. '. Use ;unorbit to stop.', 3)
end)

