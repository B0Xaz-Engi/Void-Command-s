Window:AddCommand('AutoClick', {'ClickDelay','ReleaseDelay'}, 'Automatically clicks the mouse.', function(a)
    local cd = tonumber(a[1]) or 0.05; local rd = tonumber(a[2]) or 0.05
    autoClickConn = Kill(autoClickConn)
    local lastTime = 0; local state = 'idle'
    autoClickConn = RunService.Heartbeat:Connect(function()
        local now = os.clock()
        if state == 'idle' and now - lastTime >= cd then
            pcall(mouse1press); lastTime = now; state = 'pressed'
        elseif state == 'pressed' and now - lastTime >= rd then
            pcall(mouse1release); lastTime = now; state = 'idle'
        end
    end)
    N('AutoClick', 'ON. ;noautoclick to stop.')
end)

