    local ChatGui = LocalPlayer.PlayerGui:FindFirstChild('Chat')
    if ChatGui then
        for _, v in pairs(ChatGui:GetDescendants()) do
            if v:IsA('TextLabel') then v.Text = '' end
        end
    end
end)

Window:AddCommand('Chat', {'Message'}, 'Sends a chat message.', function(Arguments, Speaker)
    local ChatEvents = game:GetService('ReplicatedStorage'):FindFirstChild('DefaultChatSystemChatEvents')
    if ChatEvents then
        ChatEvents.SayMessageRequest:FireServer(Arguments[1], 'All')
    end
end)

Window:AddCommand('Desc', {'Player'}, 'Prints a player\'s profile URL.', function(Arguments, Speaker)
    local target = findPlayer(Arguments[1]) or Speaker
    print('https://www.roblox.com/users/' .. target.UserId .. '/profile')
end)

Window:AddCommand('Kick', {'Player'}, 'Kicks a player.', function(Arguments, Speaker)
    local target = findPlayer(Arguments[1])
    if target then target:Kick('You have been kicked.') end
end)

Window:AddCommand('Disconnect', {}, 'Disconnects you from the server.', function(Arguments, Speaker)
    LocalPlayer:Kick('Disconnected by command.')
end)

Window:AddCommand('BTools', {}, 'Gives you building tools.', function(Arguments, Speaker)
    local tools = {'Clone', 'Delete', 'Move'}
    for _, name in pairs(tools) do
        local tool = Instance.new('Tool')
        tool.Name = name .. ' Tool'
        tool.Parent = Speaker.Backpack
    end
end)

