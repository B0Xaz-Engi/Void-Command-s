Window:AddCommand('Bang', {'Player','Speed'}, 'Sticks behind a player and rams their back (CFrame-locked, gradual stop to prevent fling).', function(a, s)
    local t = findPlayer(a[1])
    local r = R(s)
    if not r or not t then return end

    local char = t.Character
    local tr = char and char:FindFirstChild("HumanoidRootPart")
    if not tr then return end

    local hum = r.Parent:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = true end

    pcall(function() r:SetNetworkOwner(nil) end)

    local baseDist = 4
    r.CFrame = tr.CFrame * CFrame.new(0, 0, -baseDist)

    local sp = tonumber(a[2]) or 8
    local amp = 1.2
    local tm = 0

    local cn
    cn = RunService.Heartbeat:Connect(function(dt)
        char = t.Character
        tr = char and char:FindFirstChild("HumanoidRootPart")
        r = R(s)
        if not tr or not r or not r.Parent then
            cn:Disconnect()
            if hum then hum.PlatformStand = false end
            return
        end

        local baseCF = tr.CFrame * CFrame.new(0, 0, -baseDist)
        tm = tm + dt * sp
        local osc = math.sin(tm) * amp
        local oscDist = -baseDist + osc

        local finalPos = baseCF.Position + (baseCF.LookVector * oscDist)
        r.CFrame = CFrame.lookAt(finalPos, finalPos + baseCF.LookVector)
    end)

    task.spawn(function()
        task.wait(15)

        local fadeDuration = 1.5
        local fadeStart = tick()
        while tick() - fadeStart < fadeDuration do
            local elapsed = tick() - fadeStart
            local progress = elapsed / fadeDuration
            local currentAmp = amp * (1 - progress)

            char = t.Character
            tr = char and char:FindFirstChild("HumanoidRootPart")
            r = R(s)
            if not tr or not r then break end

            local baseCF = tr.CFrame * CFrame.new(0, 0, -baseDist)
            local oscDist = -baseDist + (math.sin(tm) * currentAmp)
            local finalPos = baseCF.Position + (baseCF.LookVector * oscDist)
            r.CFrame = CFrame.lookAt(finalPos, finalPos + baseCF.LookVector)

            task.wait()
        end

        r = R(s)
        if r then
            r.AssemblyLinearVelocity = Vector3.zero
            r.AssemblyAngularVelocity = Vector3.zero
        end

        if hum then
            hum.PlatformStand = false
            task.wait(0.2)
        end

        if cn.Connected then cn:Disconnect() end
        N('Bang', 'Stopped smoothly on ' .. t.Name .. ' (no fling)')
    end)

    N('Bang', 'Locked behind & ramming ' .. t.Name .. ' (speed: ' .. sp .. ')')
end)

