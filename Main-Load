Registry['breakloops'] = function(a, s)
    bounceConn=Kill(bounceConn);       hoverConn=Kill(hoverConn)
    flyCircleConn=Kill(flyCircleConn); rainbowConn=Kill(rainbowConn)
    ghostConn=Kill(ghostConn);         speedoConn=Kill(speedoConn)
