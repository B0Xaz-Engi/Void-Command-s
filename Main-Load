-- ============================================================
-- PLAYER FINDER - fuzzy/partial match, picks closest name
-- ============================================================
local function findPlayer(name)
    if not name or name == '' then return nil end
    local query = name:lower()
    local bestPlayer = nil
    local bestScore  = math.huge

    for _, p in pairs(Players:GetPlayers()) do
        local uname = p.Name:lower()
        local dname = p.DisplayName:lower()

        -- Exact match wins immediately
        if uname == query or dname == query then return p end

        -- Starts-with match (score = position 1, prefer shorter names)
        local uStart = uname:sub(1, #query) == query
        local dStart = dname:sub(1, #query) == query
        if uStart or dStart then
            local score = #uname  -- shorter name = better score
            if score < bestScore then bestScore = score; bestPlayer = p end
        end

        -- Contains match (fallback, penalised)
        local uContains = uname:find(query, 1, true)
        local dContains = dname:find(query, 1, true)
        if (uContains or dContains) and bestScore == math.huge then
            local score = #uname + 100
            if score < bestScore then bestScore = score; bestPlayer = p end
        end
    end

    return bestPlayer
end

