    antiKillConn=Kill(antiKillConn);   antiTPConn=Kill(antiTPConn)
    antiSlowConn=Kill(antiSlowConn);   antiDmgConn=Kill(antiDmgConn)
    antiRagConn=Kill(antiRagConn);     antiSeatConn=Kill(antiSeatConn)
    loopWpConn=Kill(loopWpConn);       discoConn=Kill(discoConn)
    magnetConn=Kill(magnetConn)
    healthRegenConn=Kill(healthRegenConn)
