    flyConn = Kill(flyConn)
    for _, v in pairs(r:GetChildren()) do
        if v:IsA('BodyVelocity') or v:IsA('BodyGyro') then v:Destroy() end
    end
    flySpeed = tonumber(a[1]) or flySpeed
    local bv = Instance.new('BodyVelocity', r)
    bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    local bg = Instance.new('BodyGyro', r)
