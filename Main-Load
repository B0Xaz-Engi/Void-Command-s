local function charParts(p)
    local c = C(p); if not c then return {} end
    local out = {}
    for _, v in pairs(c:GetDescendants()) do
        if v:IsA('BasePart') then out[#out+1] = v end
    end
    return out
end

local function cleanChildren(inst, className)
    for _, v in pairs(inst:GetChildren()) do
        if v:IsA(className) then v:Destroy() end
    end
end

local function findPlayer(name)
    if not name or name == '' then return nil end
    local q = name:lower()
    if q == 'me' or q == 'self' then return LocalPlayer end
    if q == 'random' or q == 'rand' then
        local pl = Players:GetPlayers()
        local others = {}
        for _, p in pairs(pl) do if p ~= LocalPlayer then others[#others+1] = p end end
        if #others == 0 then return LocalPlayer end
        return others[math.random(1, #others)]
    end
    local best, bestScore = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        local u = p.Name:lower()
        local d = p.DisplayName:lower()
        if u == q or d == q then return p end
        if u:sub(1,#q) == q or d:sub(1,#q) == q then
            if #u < bestScore then bestScore = #u; best = p end
        end
        if (u:find(q,1,true) or d:find(q,1,true)) and not best then
            best = p
        end
    end
    return best
end

