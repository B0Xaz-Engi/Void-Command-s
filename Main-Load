    hoverNameConn = Kill(hoverNameConn)
    local gui = Instance.new('ScreenGui'); gui.Name = 'V0idHoverName'; gui.ResetOnSpawn = false
    local frame = Instance.new('Frame', gui)
    frame.Size = UDim2.new(0, 220, 0, 50); frame.BackgroundTransparency = 0.3
    frame.BackgroundColor3 = Color3.fromRGB(0,0,0); frame.Visible = false; frame.ZIndex = 10
    Instance.new('UICorner', frame).CornerRadius = UDim.new(0, 8)
    local nameLbl = Instance.new('TextLabel', frame)
    nameLbl.Size = UDim2.new(1,0,0.55,0); nameLbl.BackgroundTransparency = 1
    nameLbl.TextColor3 = Color3.fromRGB(255,255,255); nameLbl.TextScaled = true
    nameLbl.Font = Enum.Font.GothamBold; nameLbl.ZIndex = 11
    local idLbl = Instance.new('TextLabel', frame)
    idLbl.Size = UDim2.new(1,0,0.45,0); idLbl.Position = UDim2.new(0,0,0.55,0)
    idLbl.BackgroundTransparency = 1; idLbl.TextColor3 = Color3.fromRGB(180,180,180)
    idLbl.TextScaled = true; idLbl.Font = Enum.Font.Gotham; idLbl.ZIndex = 11
