local prefix   = ';'
local Registry = {}

local _libAddCommand = Window.AddCommand
Window.AddCommand = function(self, cmdName, args, desc, callback)
    Registry[cmdName:lower()] = callback
    return _libAddCommand(self, cmdName, args, desc, callback)
end

local function execute(msg)
    if type(msg) ~= 'string' or msg == '' then return end
    msg = msg:match('^%s*(.-)%s*$')
    if #msg < #prefix + 1 then return end  -- too short to be a command
    if msg:sub(1, #prefix) ~= prefix then return end
    local parts = {}
    for w in msg:gmatch('%S+') do parts[#parts+1] = w end
    if #parts == 0 then return end
    local cmd  = parts[1]:lower()
    local args = {}
    for i = 2, #parts do args[#args+1] = parts[i] end
    local fn = Registry[cmd]
    if fn then
        local ok, err = pcall(fn, args, LocalPlayer)
        if not ok then
            N('Error', '['..cmd..']: '..tostring(err), 5)
            warn('[V0id] '..cmd..': '..tostring(err))
        end
    end
end

