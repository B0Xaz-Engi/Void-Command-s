local CommandRegistry = {}
local currentPrefix = ';'

local originalAddCommand = Window.AddCommand
Window.AddCommand = function(self, name, args, desc, callback)
    CommandRegistry[name:lower()] = callback
    return originalAddCommand(self, name, args, desc, callback)
end

local originalChangePrefix = Window.ChangePrefix
Window.ChangePrefix = function(self, newPrefix)
    currentPrefix = newPrefix
    return originalChangePrefix(self, newPrefix)
end

local function parseAndExecute(message)
    if message:sub(1, #currentPrefix) ~= currentPrefix then return end
    message = message:sub(#currentPrefix + 1)
    local parts = message:split(' ')
    local commandName = parts[1]:lower()
    local arguments = {}
    for i = 2, #parts do
        table.insert(arguments, parts[i])
    end
    if CommandRegistry[commandName] then
        CommandRegistry[commandName](arguments, LocalPlayer)
    end
end

LocalPlayer.Chatted:Connect(function(message)
    parseAndExecute(message)
end)

local function getCharacter(speaker)
    return speaker and speaker.Character
end

local function getHumanoid(speaker)
    local char = getCharacter(speaker)
    return char and char:FindFirstChildOfClass('Humanoid')
end

local function getHRP(speaker)
    local char = getCharacter(speaker)
    return char and char:FindFirstChild('HumanoidRootPart')
end

local function findPlayer(name)
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name) or p.DisplayName:lower():find(name) then
            return p
        end
    end
end

