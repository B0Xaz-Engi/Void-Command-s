Window:AddCommand('CircleTP', {'Radius','Steps'}, 'TPs around a circle (no loop).', function(a, s)
    local rad = tonumber(a[1]) or 15; local steps = tonumber(a[2]) or 8
    local r = R(s); if not r then return end
    local center = r.Position
    task.spawn(function()
        for i = 1, steps do
            local r2 = R(s); if not r2 then return end
            local ang = (i/steps)*math.pi*2
            r2.CFrame = CFrame.new(center.X+math.cos(ang)*rad, center.Y, center.Z+math.sin(ang)*rad)
            task.wait(0.1)
        end
    end)
    N('CircleTP', 'Done.')
end)

Window:AddCommand('Zigzag', {'Width','Steps'}, 'TPs in a zigzag forward.', function(a, s)
    local w = tonumber(a[1]) or 5; local steps = tonumber(a[2]) or 10
    task.spawn(function()
        for i = 1, steps do
            local r2 = R(s); if not r2 then return end
            r2.CFrame = r2.CFrame + r2.CFrame.LookVector*5 + r2.CFrame.RightVector*((i%2==0 and w or -w))
            task.wait(0.08)
        end
    end)
end)

