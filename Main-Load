Window:AddCommand('ESP', {}, 'Draws selection boxes around all players.', function(a, s)
    for _, v in pairs(LocalPlayer.PlayerGui:GetDescendants()) do
        if v.Name:find('V0idESP') then v:Destroy() end
    end
    espObjs = {}; espUpdateConn = Kill(espUpdateConn)

    local function makeBox(p)
        if p == s or not p.Character then return end
        local box = Instance.new('SelectionBox')
        box.Adornee = p.Character
        box.Color3 = Color3.fromRGB(255, 0, 0)
        box.LineThickness = 0.05
        box.Name = 'V0idESP_'..p.Name
        box.Parent = LocalPlayer.PlayerGui
        espObjs[p.Name] = box
    end

    for _, p in pairs(Players:GetPlayers()) do makeBox(p) end

    espUpdateConn = Players.PlayerAdded:Connect(makeBox)
    local charConn = Players.PlayerRemoving:Connect(function(p)
        if espObjs[p.Name] then espObjs[p.Name]:Destroy(); espObjs[p.Name] = nil end
    end)
    RunService.Heartbeat:Connect(function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= s and espObjs[p.Name] and p.Character then
                espObjs[p.Name].Adornee = p.Character
            elseif p ~= s and not espObjs[p.Name] and p.Character then
                makeBox(p)
            end
        end
    end)
    N('ESP', 'ON. ;noesp to remove.')
end)

