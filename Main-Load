local function doGoto(a,s)
    local name=table.concat(a,' ')
    if name=='' then N('Goto','Usage: ;goto / ;to / ;tp <player>') return end
    local t=findPlayer(name); local r=R(s)
    if not r then return end
    if not t then N('Goto','Not found: '..name) return end
    local tr=t.Character and t.Character:FindFirstChild('HumanoidRootPart')
    if tr then r.CFrame=tr.CFrame+Vector3.new(3,0,0); N('Goto','Teleported to '..t.Name..'.')
    else N('Goto',t.Name..' has no character.') end
end
